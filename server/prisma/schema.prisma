
datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

generator client {
  provider      = "prisma-client-js"
}

// --- CORE MODELS ---
model User {
  id              String           @id @default(cuid())
  email           String           @unique
  name            String?
  role            String           @default("GUEST") // Was UserRole
  walletAddress   String?          @unique
  password        String?          // For non-web3 logins
  avatar          String?
  createdAt       DateTime         @default(now())
  updatedAt       DateTime         @updatedAt
  
  // Original relations from your schema
  sessions        Session[]
  readingSessions ReadingSession[]

  // New relations for KalaKrut Platform
  artistProfile    ArtistProfile?
  proposals        DAOProposal[]
  votes            DAOVote[]
  delegationsFrom  DAODelegation[]   @relation("Delegator")
  delegationsTo    DAODelegation[]   @relation("Delegatee")
  moderationCases  ModerationCase[]
  ownedNFTs        NFT[]             @relation("Owner")
  createdNFTs      NFT[]             @relation("Creator")
  tickets          EventTicket[]
  fractionalTokens FractionalTokenHolder[]
  escrowsAsArbiter EscrowContract[]  @relation("Arbiter")
  escrowsAsBeneficiary EscrowContract[] @relation("Beneficiary")
  marketplaceListings MarketplaceListing[]
  bookings         Booking[]         @relation("BookedUser")
  managedBookings  Booking[]         @relation("ArtistManager")
  leads            Lead[]
}

model ArtistProfile {
  id            String   @id @default(cuid())
  user          User     @relation(fields: [userId], references: [id])
  userId        String   @unique
  bio           String?
  location      String?
  musicBrainzId String?  @unique
  verified      Boolean  @default(false)
  coverImage    String?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
}

// --- ORIGINAL MODELS (UNCHANGED) ---
model Session {
  id             String    @id @default(cuid())
  sessionToken   String    @unique
  userId         String
  expires        DateTime
  user           User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt
  readings       Reading[]
  metrics        Metrics[]
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

model Book {
  id              String           @id @default(cuid())
  title           String
  author          String
  cover           String
  totalPages      Int
  readingSessions ReadingSession[]
  createdAt       DateTime         @default(now())
  updatedAt       DateTime         @updatedAt
}

model ReadingSession {
  id          String    @id @default(cuid())
  user        User      @relation(fields: [userId], references: [id])
  userId      String
  book        Book      @relation(fields: [bookId], references: [id])
  bookId      String
  readings    Reading[]
  start       DateTime  @default(now())
  end         DateTime?
  currentPage Int       @default(0)
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
}

model Reading {
  id               String         @id @default(cuid())
  session          Session        @relation(fields: [sessionId], references: [id])
  sessionId        String
  readingSession   ReadingSession @relation(fields: [readingSessionId], references: [id])
  readingSessionId String
  start            DateTime
  end              DateTime
  wordCount        Int
  wordsPerMinute   Int
  createdAt        DateTime       @default(now())
  updatedAt        DateTime       @updatedAt
}

model Metrics {
  id             String   @id @default(cuid())
  session        Session  @relation(fields: [sessionId], references: [id])
  sessionId      String
  metricType     String
  value          Float
  start          DateTime
  end            DateTime
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt
}


// --- NEW MODELS FOR KALAKRUT PLATFORM ---

// Core DAO Contracts
model KalaKrutToken {
  id        String   @id @default(cuid())
  address   String   @unique
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Timelock {
  id        String   @id @default(cuid())
  address   String   @unique
  minDelay  Int
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model KalaKrutGovernor {
  id              String   @id @default(cuid())
  address         String   @unique
  tokenAddress    String
  timelockAddress String
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
}

model Treasury {
  id        String   @id @default(cuid())
  address   String   @unique
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}


// DAO & Governance
model DAOProposal {
  id                String         @id
  proposer          User           @relation(fields: [proposerId], references: [id])
  proposerId        String
  title             String
  description       String
  status            String         @default("PENDING") // Was ProposalStatus
  creationTimestamp DateTime
  startTimestamp    DateTime
  endTimestamp      DateTime
  votes             DAOVote[]
  createdAt         DateTime       @default(now())
  updatedAt         DateTime       @updatedAt
}

model DAOVote {
  id            String      @id @default(cuid())
  proposal      DAOProposal @relation(fields: [proposalId], references: [id])
  proposalId    String
  voter         User        @relation(fields: [voterId], references: [id])
  voterId       String
  support       String      // Was VoteType
  votingPower   Float
  timestamp     DateTime
  createdAt     DateTime    @default(now())
  updatedAt     DateTime    @updatedAt
  @@unique([proposalId, voterId])
}

model DAODelegation {
  id             String   @id @default(cuid())
  delegator      User     @relation("Delegator", fields: [delegatorId], references: [id])
  delegatorId    String   @unique
  delegatee      User     @relation("Delegatee", fields: [delegateeId], references: [id])
  delegateeId    String
  timestamp      DateTime
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt
}

// NFT & Tokens
model NFT {
  id                String   @id @default(cuid())
  tokenId           Int      @unique
  name              String
  symbol            String
  tokenURI          String
  owner             User     @relation("Owner", fields: [ownerId], references: [id])
  ownerId           String
  creator           User     @relation("Creator", fields: [creatorId], references: [id])
  creatorId         String
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt
  fractionalizedNFT FractionalizedNFT? 
}

model Event {
  id          String   @id @default(cuid())
  name        String
  description String?
  uri         String   @unique // ERC1155 URI
  date        DateTime
  location    String
  tickets     EventTicket[]
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model EventTicket {
  id        String   @id @default(cuid())
  event     Event    @relation(fields: [eventId], references: [id])
  eventId   String
  owner     User     @relation(fields: [ownerId], references: [id])
  ownerId   String
  tokenId   Int      // The specific ERC1155 token ID for this ticket type
  balance   Int      // How many tickets this user owns
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  @@unique([eventId, ownerId, tokenId])
}

model FractionalizedNFT {
  id                 String   @id @default(cuid())
  originalNFT        NFT      @relation(fields: [nftId], references: [id])
  nftId              String   @unique
  name               String   // Name of the fractional token (e.g., "Fraction of MyArt")
  symbol             String   // Symbol (e.g., "FMA")
  totalSupply        BigInt
  tokenContractAddress String   @unique
  holders            FractionalTokenHolder[]
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt
}

model FractionalTokenHolder {
  id                 String            @id @default(cuid())
  fractionalizedNFT  FractionalizedNFT @relation(fields: [fractionalizedNFTId], references: [id])
  fractionalizedNFTId String
  holder             User              @relation(fields: [holderId], references: [id])
  holderId           String
  balance            BigInt
  createdAt          DateTime          @default(now())
  updatedAt          DateTime          @updatedAt
  @@unique([fractionalizedNFTId, holderId])
}

// Contracts & Services
model EscrowContract {
  id           String       @id @default(cuid())
  arbiter      User         @relation("Arbiter", fields: [arbiterId], references: [id])
  arbiterId    String
  beneficiary  User         @relation("Beneficiary", fields: [beneficiaryId], references: [id])
  beneficiaryId String
  amount       Float
  status       String       @default("PENDING") // Was EscrowStatus
  contractAddress String?   @unique
  createdAt    DateTime     @default(now())
  updatedAt    DateTime     @updatedAt
}

model MarketplaceListing {
  id          String        @id @default(cuid())
  seller      User          @relation(fields: [sellerId], references: [id])
  sellerId    String
  assetType   String        // e.g., "NFT", "EventTicket"
  assetId     String        // The ID of the NFT or EventTicket
  price       Float
  currency    String        @default("USD")
  status      String        @default("ACTIVE") // Was ListingStatus
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt
}

model Booking {
  id              String        @id @default(cuid())
  bookedUser      User          @relation("BookedUser", fields: [bookedUserId], references: [id])
  bookedUserId    String
  artistManager   User          @relation("ArtistManager", fields: [artistManagerId], references: [id])
  artistManagerId String
  eventDetails    String
  bookingDate     DateTime
  status          String        @default("REQUESTED") // Was BookingStatus
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt
}

// Admin & Moderation
model Lead {
  id        String     @id @default(cuid())
  user      User       @relation(fields: [userId], references: [id])
  userId    String     @unique
  status    String     @default("NEW")
  notes     String?
  createdAt DateTime   @default(now())
  updatedAt DateTime   @updatedAt
}

model ModerationCase {
  id             String   @id @default(cuid())
  user           User     @relation(fields: [userId], references: [id])
  userId         String
  violationType  String
  contentSnippet String?
  status         String
  appealReason   String?
  timestamp      DateTime
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt
}
